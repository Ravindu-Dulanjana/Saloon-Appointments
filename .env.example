# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin dashboard — comma-separated list of emails allowed to sign in
ADMIN_EMAILS=you@example.com,another@example.com

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886


# Salon
SALON_NAME=Glow Salon
SALON_TIMEZONE=Asia/Colombo

# Cron security (a random string you set in Vercel Cron header)
CRON_SECRET=replace-with-random-string
